# free = use the no-key open-source World Cup 2026 API.
# mock/demo = use local demo data.
# api/api-football = use paid API-Football with API_FOOTBALL_KEY.
DATA_MODE=free
PORT=3000
REFRESH_CACHE_SECONDS=60

# Free public World Cup 2026 API. No API key required.
FREE_API_URL=https://worldcup26.ir/get/games
FREE_TEAMS_URL=https://worldcup26.ir/get/teams
FREE_STADIUMS_URL=https://worldcup26.ir/get/stadiums

# Optional paid API-Football mode. Keep the key on server only, never in frontend JS.
API_FOOTBALL_KEY=your_api_key_here
WORLD_CUP_LEAGUE_ID=1
WORLD_CUP_SEASON=2026

# Match display is normalized to Vietnam time on the frontend.
DISPLAY_TIMEZONE=Asia/Ho_Chi_Minh
DISPLAY_TIMEZONE_LABEL=UTC+7
